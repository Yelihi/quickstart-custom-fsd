{
  "name": "quickstart-custom-plate",
  "version": "1.3.0",
  "description": "초기 프론트엔드 설정 세팅입니다",
  "type": "module",
  "bin": {
    "quickstart": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run src/__tests__/scaffold.integration.test.ts",
    "verify:e2e": "npx tsx scripts/verify-e2e.ts",
    "prepublishOnly": "npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "yelihi",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/prompts": "^2.4.9",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  }
}
